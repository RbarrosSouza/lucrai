      "parameters": {
        "jsCode": "const dados = $input.item.json.dados_inteligencia || {};\nconst mensagem = $('Set mensagens1').first().json.mensagem.toLowerCase();\n\nconst historico = dados.historico || [];\nconst categorias = dados.categorias || [];\nconst centros = dados.centros || [];\n\n// Map auxiliar para resolver nome da categoria DRE de cada cost_center\nconst categoriasMap = new Map(categorias.map(c => [c.id, c.name]));\n\n// --- PALAVRAS CHAVE (Fallback) ---\nconst palavrasChave = {\n  combustivel: ['gasolina', 'diesel', 'posto', 'abastecimento'],\n  pessoal: ['plantonista', 'plantão', 'salário', 'funcionário'],\n  medicamentos: ['vacina', 'medicamento', 'farmácia', 'drogaria'],\n  servicos: ['contador', 'limpeza', 'manutenção', 'marketing'],\n  utilidades: ['luz', 'energia', 'agua', 'internet', 'telefone']\n};\n\n// --- PONTUAÇÃO (continua usando categorias para inferência semântica) ---\nconst candidatos = categorias.map(cat => {\n    let pontos = 0;\n    let razoes = [];\n\n    if (mensagem.includes(cat.name.toLowerCase())) {\n        pontos += 2000;\n        razoes.push(`Você citou a categoria '${cat.name}'`);\n    }\n\n    const matchHist = historico.find(h => h.category_id === cat.id);\n    if (matchHist) {\n        if (matchHist.fornecedor_encontrado) {\n             pontos += 500 + (matchHist.frequencia * 10);\n             razoes.push(`Padrão do fornecedor ${matchHist.fornecedor_encontrado}`);\n        } else {\n             pontos += 100;\n             razoes.push(`Histórico similar encontrado`);\n        }\n    }\n\n    for (const [key, words] of Object.entries(palavrasChave)) {\n        if (words.some(w => mensagem.includes(w))) {\n            if (cat.name.toLowerCase().includes(key)) {\n                pontos += 50;\n                razoes.push(`Palavra-chave: ${key}`);\n            }\n        }\n    }\n\n    return { ...cat, pontos, razoes };\n});\n\ncandidatos.sort((a, b) => b.pontos - a.pontos);\nconst vencedor = candidatos[0];\n\nlet decisao = {\n    aprovado: false,\n    categoria: null,\n    centro_custo: null,\n    razao: \"Incerteza\",\n    alternativas: []\n};\n\nif (vencedor && vencedor.pontos >= 150) {\n    decisao.aprovado = true;\n    decisao.categoria = vencedor;\n    decisao.razao = vencedor.razoes.join(', ');\n    const histVencedor = historico.find(h => h.category_id === vencedor.id);\n    if (histVencedor && histVencedor.cost_center_id) {\n        decisao.centro_custo = centros.find(c => c.id === histVencedor.cost_center_id);\n    }\n} else {\n    decisao.alternativas = candidatos.slice(0, 3).map(c => `- ${c.name} (ID: ${c.id})`);\n}\n\nlet dadosOriginais = {};\ntry { dadosOriginais = $('Set mensagens1').first().json; } catch(e) {}\n\n// Versão completa: cada centro com sua categoria DRE expandida (modo confirmação)\nconst centrosFull = centros.map(c => {\n    const categoriaNome = categoriasMap.get(c.default_category_id) || '???';\n    return `- ${c.name}\\n    cost_center_id: ${c.id}\\n    pertence à categoria DRE: \"${categoriaNome}\"`;\n}).join('\\n');\n\n// Versão compacta: 1 linha por centro (modo automático — economiza ~3k tokens)\nconst centrosCompact = centros.map(c => {\n    const categoriaNome = categoriasMap.get(c.default_category_id) || '???';\n    return `- ${c.name} → ${categoriaNome} (cost_center_id: ${c.id})`;\n}).join('\\n');\n\nconst categoriasFull = categorias.map(c => {\n    const parts = [];\n    if (c.grandparent_name) parts.push(c.grandparent_name);\n    if (c.parent_name) parts.push(c.parent_name);\n    parts.push(c.name);\n    return `- ${parts.join(' > ')}`;\n}).join('\\n');\n\nlet promptContexto;\nif (decisao.aprovado) {\n    // Motor confiante: contexto enxuto\n    const cat = decisao.categoria;\n    const caminhoDRE = cat ? [cat.grandparent_name, cat.parent_name, cat.name].filter(Boolean).join(' > ') : '—';\n    promptContexto = `\n📦 **DECISÃO DO MOTOR DE INTELIGÊNCIA**\n\n✅ MODO AUTOMÁTICO ATIVADO\n\n**Dados da Inferência:**\n- Categoria Sugerida: ${cat?.name || \"—\"}\n- Caminho DRE: ${caminhoDRE}\n- Centro de Custo Sugerido: ${decisao.centro_custo?.name || \"—\"} ${decisao.centro_custo ? `(cost_center_id: ${decisao.centro_custo.id})` : \"\"}\n- Motivo: ${decisao.razao}\n\n---\n\n🎯 **CENTROS OPERACIONAIS** (lista compacta — escolha UM cost_center_id; category_id é derivado automaticamente):\n\n${centrosCompact}\n`;\n} else {\n    // Motor em dúvida: contexto completo\n    promptContexto = `\n📦 **DECISÃO DO MOTOR DE INTELIGÊNCIA**\n\n⚠️ MODO DE CONFIRMAÇÃO\n\n**Dados da Inferência:**\n- Categoria Sugerida: ${decisao.categoria?.name || \"—\"}\n- Centro de Custo Sugerido: ${decisao.centro_custo?.name || \"—\"} ${decisao.centro_custo ? `(cost_center_id: ${decisao.centro_custo.id})` : \"\"}\n- Motivo: ${decisao.razao}\n\n**Alternativas de categoria:**\n${decisao.alternativas.join('\\n')}\n\n---\n\n🎯 **CENTROS OPERACIONAIS** (a Lu escolhe UM cost_center_id desta lista; o category_id é derivado automaticamente):\n\n${centrosFull}\n\n---\n\n📊 **Categorias DRE** (apenas referência — você NÃO precisa escolher manualmente; vem do cost_center. Use este caminho ao mostrar a categoria na resposta):\n${categoriasFull}\n`;\n}\n\nreturn { \n    json: { \n        ...dadosOriginais,\n        contexto_financeiro: promptContexto,\n        inferencia: decisao \n    } \n};"
      },
