      "parameters": {
        "operation": "executeQuery",
        "query": "-- MOTOR INTELIGENTE V3 (Com Detecção de Fornecedor)\nWITH fornecedor_detectado AS (\n    -- 1. Varre a tabela de fornecedores para ver se algum nome aparece na mensagem do usuário\n    SELECT id, name\n    FROM suppliers\n    WHERE org_id = $1\n      AND LENGTH(name) > 2 -- Evita match com nomes curtos demais\n      AND $2 ILIKE '%' || name || '%' -- O segredo: Verifica se o NOME está na MENSAGEM\n    LIMIT 1\n),\n\nhistorico AS (\n    SELECT \n        c.id as category_id,\n        c.name as category_name,\n        c.type as category_type,\n        cc.id as cost_center_id,\n        cc.name as cost_center_name,\n        f.name as fornecedor_encontrado,\n        COUNT(*) as frequencia\n    FROM transactions t\n    JOIN categories c ON t.category_id = c.id\n    LEFT JOIN cost_centers cc ON t.cost_center_id = cc.id\n    LEFT JOIN fornecedor_detectado f ON t.supplier_id = f.id\n    WHERE t.org_id = $1\n      AND (\n          -- Busca histórico desse fornecedor (se detectado)\n          t.supplier_id = (SELECT id FROM fornecedor_detectado)\n          OR \n          -- OU busca por palavras similares na descrição (Fallback)\n          t.description ILIKE '%' || SPLIT_PART($2, ' ', 1) || '%'\n      )\n      AND t.created_at > NOW() - INTERVAL '180 days'\n    GROUP BY c.id, c.name, c.type, cc.id, cc.name, f.name\n    ORDER BY frequencia DESC\n    LIMIT 3\n),\n\ntodas_categorias AS (\n    SELECT c.id, c.name, c.type, c.is_group, c.is_active,\n           c.parent_id, p.name AS parent_name,\n           p.parent_id AS grandparent_id, gp.name AS grandparent_name\n    FROM categories c\n    LEFT JOIN categories p ON p.id = c.parent_id\n    LEFT JOIN categories gp ON gp.id = p.parent_id\n    WHERE c.org_id = $1 AND c.is_active = true AND c.is_group = false\n),\n\ntodos_centros AS (\n    SELECT id, name, dre_category_id as default_category_id FROM cost_centers WHERE org_id = $1 AND is_active = true\n)\n\nSELECT json_build_object(\n    'historico', (SELECT json_agg(row_to_json(historico.*)) FROM historico),\n    'categorias', (SELECT json_agg(row_to_json(todas_categorias.*)) FROM todas_categorias),\n    'centros', (SELECT json_agg(row_to_json(todos_centros.*)) FROM todos_centros)\n) as dados_inteligencia;",
        "options": {
          "queryReplacement": "={{ $('Set mensagens1').first().json.org_id }}, {{ $('Set mensagens1').first().json.mensagem }}"
        }
