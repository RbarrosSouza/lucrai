        "jsCode": "// Explode body.attachments[] em N items, um por anexo, replicando o body.\n// Mensagens sem anexos passam adiante intactas (1 item).\nconst item = $input.item.json;\nconst body = item.body || {};\nconst attachments = Array.isArray(body.attachments) ? body.attachments : [];\n\nif (attachments.length <= 1) {\n  // 0 ou 1 anexo: passa intacto (preserva semântica original)\n  return [{ json: { ...item, _attachment_index: 0, _attachment_total: attachments.length || 0 } }];\n}\n\n// Múltiplos anexos: cria 1 item por anexo, mantendo body.attachments=[anexo_n]\nreturn attachments.map((att, idx) => ({\n  json: {\n    ...item,\n    body: { ...body, attachments: [att] },\n    _attachment_index: idx,\n    _attachment_total: attachments.length,\n  }\n}));\n"
