    {
      "parameters": {
        "jsCode": "// === MODO TESTE ===\n// Quando FORCAR_TESTE = true, ignora janela horária e dispara TIPO_TESTE_MANUAL.\n// ⚠️ TROCAR PARA false ANTES DE COLOCAR EM PRODUÇÃO (senão o cron vai mandar mensagem toda hora).\nconst FORCAR_TESTE = false;\nconst TIPO_TESTE_MANUAL = 'L1_weekly';\n// Tipos válidos: L1_weekly, L2_dminus1, L3_recurrence, L4_dzero, R1_morning, R2_weekly, R3_monthly\n\nconst spData = $input.first().json;\nconst hora = spData.hora_sp;\nconst dow  = spData.dow_sp;\nconst dia  = spData.dia_sp;\n\nconst ctx = {hora, dow, dia};\nconst tipos = [];\n\nif (FORCAR_TESTE) {\n  // Modo teste → força o tipo configurado, ignora janela horária.\n  // Gates de notification_log continuam valendo (não duplica envio).\n  tipos.push({tipo: TIPO_TESTE_MANUAL, ...ctx, _teste: true});\n} else {\n  // Produção → checa janela horária real.\n  // DOW: 0=dom 1=seg 2=ter 3=qua 4=qui 5=sex 6=sab\n  if (dow === 1 && hora === 8)  tipos.push({tipo: 'L1_weekly', ...ctx});\n  if (hora === 18)              tipos.push({tipo: 'L2_dminus1', ...ctx});\n  if (hora === 9)               tipos.push({tipo: 'L3_recurrence', ...ctx});\n  if (hora === 19)              tipos.push({tipo: 'L4_dzero', ...ctx});\n  if (hora >= 7 && hora <= 10)  tipos.push({tipo: 'R1_morning', ...ctx});\n  if (dow === 5 && hora === 17) tipos.push({tipo: 'R2_weekly', ...ctx});\n  if (dia === 1 && hora === 8)  tipos.push({tipo: 'R3_monthly', ...ctx});\n}\n\nif (!tipos.length) return [{json: {_debug: true, hora, dow, dia, FORCAR_TESTE, nenhum_tipo_ativo: true}}];\n\nreturn tipos.map(t => ({json: t}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [0, 0],
      "id": "10000002-0000-0000-0000-000000000002",
      "name": "Calcular Tipos Ativos"
