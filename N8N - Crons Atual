    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH historico AS (SELECT supplier_id, description, amount, date, date_trunc('month', date) as mes, EXTRACT(DAY FROM date)::int as dia FROM transactions WHERE org_id = '{{ $('Loop Orgs L3').item.json.org_id }}' AND type='EXPENSE' AND status='PAID' AND date >= current_date - interval '6 months'), grupos AS (SELECT h1.supplier_id, h1.description as desc_ref, AVG(h2.amount) as valor_medio, AVG(h2.dia) as dia_medio, GREATEST(5, COALESCE(STDDEV(h2.dia), 5)) as janela, COUNT(DISTINCT h2.mes) as meses_distintos FROM historico h1 JOIN historico h2 ON h2.supplier_id = h1.supplier_id AND similarity(h1.description, h2.description) > 0.4 AND ABS(h2.amount - h1.amount) / NULLIF(h1.amount, 0) < 0.20 GROUP BY h1.supplier_id, h1.description HAVING COUNT(DISTINCT h2.mes) >= 3) SELECT DISTINCT ON (g.supplier_id) g.*, s.name as supplier_name FROM grupos g JOIN suppliers s ON s.id = g.supplier_id WHERE EXTRACT(DAY FROM current_date)::int BETWEEN GREATEST(1, (g.dia_medio - g.janela)::int) AND LEAST(31, (g.dia_medio + g.janela)::int) AND NOT EXISTS (SELECT 1 FROM transactions t WHERE t.org_id = '{{ $('Loop Orgs L3').item.json.org_id }}' AND t.supplier_id = g.supplier_id AND date_trunc('month', t.date) = date_trunc('month', current_date) AND similarity(t.description, g.desc_ref) > 0.4 AND ABS(t.amount - g.valor_medio) / NULLIF(g.valor_medio, 0) < 0.20) AND NOT EXISTS (SELECT 1 FROM notification_log nl WHERE nl.org_id = '{{ $('Loop Orgs L3').item.json.org_id }}' AND nl.notification_type = 'L3_recurrence' AND nl.supplier_id = g.supplier_id AND date_trunc('month', nl.sent_at) = date_trunc('month', current_date)) AND COALESCE(s.notify_recurrence, true) = true",
