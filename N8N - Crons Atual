      "parameters": {
        "jsCode": "const itens = $input.all();\nconst orgData = $('Loop Orgs L3').item.json;\nconst chatwoot_conversation_id = orgData.chatwoot_conversation_id;\n\nif (!chatwoot_conversation_id || !itens.length || !itens[0].json.supplier_name) return [];\n\nconst fmt = (n) => new Intl.NumberFormat('pt-BR', {minimumFractionDigits: 2}).format(n || 0);\nconst item = itens[0].json;\nconst janela = Math.round(item.janela || 5);\nconst diaInicio = Math.max(1, Math.round(item.dia_medio) - janela);\nconst diaFim = Math.min(31, Math.round(item.dia_medio) + janela);\n\nconst mensagem = `🩵 Notei um padrão aqui 👀\\n\\nTodo mês você paga *${item.supplier_name}* — em torno de *R$ ${fmt(item.valor_medio)}*, geralmente entre os dias ${diaInicio} e ${diaFim}.\\n\\nEsse mês ainda não vi esse lançamento. Quer que eu já registre?\\n\\n✅ \"sim\" — crio como pendente\\n💸 \"sim, paguei\" — marco como pago\\n🔕 \"ignorar\" — paro de avisar desse fornecedor`;\n\nreturn [{json: {\n  mensagem,\n  org_id: orgData.org_id,\n  chatwoot_conversation_id,\n  notification_type: 'L3_recurrence',\n  supplier_id: item.supplier_id\n}}];"
