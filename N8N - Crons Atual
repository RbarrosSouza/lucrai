    {
      "parameters": {
        "jsCode": "const itens = $input.all();\nconst orgData = $('Loop Orgs L1').item.json;\nconst chatwoot_conversation_id = orgData.chatwoot_conversation_id;\n\nif (!chatwoot_conversation_id || !itens.length || !itens[0].json.id) return [];\n\nconst fmt = (n) => new Intl.NumberFormat('pt-BR', {minimumFractionDigits: 2}).format(n || 0);\nconst DOW_PT = ['dom', 'seg', 'ter', 'qua', 'qui', 'sex', 'sáb'];\nconst cap = (s) => s.charAt(0).toUpperCase() + s.slice(1);\n\nconst horaCtx = $('Hora Atual SP').first().json;\nconst today = horaCtx.today_iso;\nconst tomorrow = horaCtx.tomorrow_iso;\n\n// Agrupar transações por data\nconst grupos = new Map();\nfor (const i of itens) {\n  const d = i.json;\n  if (!grupos.has(d.date_iso)) {\n    grupos.set(d.date_iso, {\n      date_iso: d.date_iso,\n      data_formatada: d.data_formatada,\n      dow: Number(d.dow),\n      itens: [],\n      total: 0\n    });\n  }\n  const g = grupos.get(d.date_iso);\n  g.itens.push(d);\n  g.total += parseFloat(d.amount || 0);\n}\n\nconst totalGeral = itens.reduce((acc, i) => acc + parseFloat(i.json.amount || 0), 0);\nconst numContas = itens.length;\n\nconst renderGrupo = (g) => {\n  let label, prefix;\n  if (g.date_iso === today) {\n    label = `*Hoje (${DOW_PT[g.dow]}, ${g.data_formatada})*`;\n    prefix = '🟠';\n  } else if (g.date_iso === tomorrow) {\n    label = `*Amanhã (${DOW_PT[g.dow]}, ${g.data_formatada})*`;\n    prefix = '🗓️';\n  } else {\n    label = `*${cap(DOW_PT[g.dow])}, ${g.data_formatada}*`;\n    prefix = '🗓️';\n  }\n  if (g.itens.length === 1) {\n    const it = g.itens[0];\n    return `${prefix} ${label} · R$ ${fmt(it.amount)} — ${it.supplier_name}`;\n  }\n  const linhas = g.itens.map(it => `   • R$ ${fmt(it.amount)} — ${it.supplier_name}`).join('\\n');\n  return `${prefix} ${label} · R$ ${fmt(g.total)}\\n${linhas}`;\n};\n\nconst blocos = Array.from(grupos.values()).map(renderGrupo).join('\\n\\n');\nconst plural = numContas === 1 ? 'conta' : 'contas';\n\nconst mensagem = `🩵 Bom dia! ☀️\\n\\nResumo da sua semana: *R$ ${fmt(totalGeral)}* em ${numContas} ${plural} a pagar\\n\\n${blocos}\\n\\nMe avisa quando pagar alguma — eu marco aqui ✅`;\n\nreturn [{json: {\n  mensagem,\n  org_id: orgData.org_id,\n  chatwoot_conversation_id,\n  notification_type: 'L1_weekly',\n  transaction_ids: itens.map(i => i.json.id)\n}}];"
      },
