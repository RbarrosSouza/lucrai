        "query": "SELECT t.id, t.description, t.amount, t.date, TO_CHAR(t.date, 'DD/MM') as data_formatada, t.date::text as date_iso, EXTRACT(DOW FROM t.date)::int as dow, COALESCE(s.name, t.description) as supplier_name FROM transactions t LEFT JOIN suppliers s ON s.id = t.supplier_id WHERE t.org_id = '{{ $('Loop Orgs L1').item.json.org_id }}' AND t.type = 'EXPENSE' AND t.status = 'PENDING' AND t.date BETWEEN current_date AND current_date + 7 AND NOT EXISTS (SELECT 1 FROM notification_log nl WHERE nl.org_id = t.org_id AND nl.transaction_id = t.id AND nl.notification_type = 'L1_weekly' AND nl.sent_at >= date_trunc('week', current_date)) ORDER BY t.date ASC LIMIT 10",
